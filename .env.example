# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=wraplab

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-key
JWT_REFRESH_SECRET=change-me-refresh-secret-key
JWT_ACCESS_EXPIRES_IN=7200
JWT_REFRESH_EXPIRES_IN=604800

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# OSS
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_REGION=oss-cn-hangzhou
OSS_CDN_DOMAIN=

# File Upload
UPLOAD_IMAGE_MAX_SIZE=10485760
UPLOAD_MODEL_MAX_SIZE=52428800
UPLOAD_DIR=./uploads

# Pricing
DEFAULT_FULL_CAR_AREA_M2=15

# CORS
CLIENT_ORIGIN=http://localhost:10086
ADMIN_ORIGIN=http://localhost:3001

# App
NODE_ENV=development
PORT=3000

# Throttle
THROTTLE_TTL=60000
THROTTLE_LIMIT=10
